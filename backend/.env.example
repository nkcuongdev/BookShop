PORT=5000
JWT_SECRET=change_me
JWT_EXPIRES_IN=7d

# Public URLs used by payment gateways when redirecting back to the app.
FRONTEND_URL=http://localhost:5173
API_PUBLIC_URL=http://localhost:5000

# Dev keeps online payment testable without real merchant credentials.
# Set PAYMENT_MOCK_ENABLED=false in production.
PAYMENT_MOCK_ENABLED=true

# VNPay sandbox/production credentials.
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:5000/api/orders/payment-return/vnpay

# MoMo sandbox/production credentials.
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_REDIRECT_URL=http://localhost:5000/api/orders/payment-return/momo
MOMO_IPN_URL=http://localhost:5000/api/orders/webhook/momo
